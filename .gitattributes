# Auto-detect text files and normalize line endings to LF on checkin
* text=auto eol=lf

# Explicitly declare text files
*.md text eol=lf
*.sh text eol=lf
*.csv text eol=lf
*.muttrc text eol=lf
*.1 text eol=lf

# Makefiles must use tabs
Makefile text eol=lf

# Shell scripts must always have LF (otherwise they break on Unix)
bin/* text eol=lf
lib/* text eol=lf
completion/* text eol=lf

# Template files
share/*-temp text eol=lf
share/*.csv text eol=lf
share/*.muttrc text eol=lf
share/mailcap text eol=lf

# Documentation
*.yml text eol=lf
LICENSE text eol=lf
README.md text eol=lf
